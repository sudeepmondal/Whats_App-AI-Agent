# ══════════════════════════════════════════════
#   WhatsApp AI Agent — Environment Variables
# ══════════════════════════════════════════════

# তোমার Groq API Key (https://console.groq.com থেকে নাও)
GROQ_API_KEY=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

# তোমার নিজের WhatsApp নম্বর (country code সহ, + ছাড়া)
# উদাহরণ: বাংলাদেশ → 8801XXXXXXXXX
MY_PHONE_NUMBER=8801710871404

# Group এ তোমার নাম যেটা দিয়ে mention করা হয়
# উদাহরণ: "Rahim", "Karim", "Boss" — যা তোমার contacts ডাকে
MY_NAME=Deep

# n8n Webhook URL (n8n যেখানে চলছে সেই address)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/whatsapp

# Gateway server port
GATEWAY_PORT=3001

# AI Model Settings
GROQ_MODEL=llama-3.3-70b-versatile
AI_PERSONALITY=friendly
# Options: friendly | professional | funny | casual

# Time-based auto reply (24-hour format)
# এই সময়ের বাইরে reply দেবে না
SLEEP_MODE_START=23
SLEEP_MODE_END=7

# Blacklisted phone numbers (comma separated, country code সহ)
# এই নম্বরগুলোকে কখনো reply দেবে না
BLACKLIST_NUMBERS=

# n8n credentials (যদি auth থাকে)
N8N_USER=admin
N8N_PASSWORD=password